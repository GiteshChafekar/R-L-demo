# Copy this file to ".env" and fill in your real values. Never commit ".env" to git.

SECRET_KEY=replace-with-a-long-random-string

# Gmail SMTP example — use a 16-character "App Password", NOT your normal Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords (requires 2-Step Verification enabled)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youraddress@gmail.com
MAIL_PASSWORD=your16charapppassword

# Optional: override the default SQLite path
# DATABASE_URL=sqlite:///instance/bank.db
